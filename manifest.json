{
  "manifest_version": 3,
  "name": "Saiba o que Assina - Privacidade com IA",
  "version": "1.0.0",
  "description": "Analisa automaticamente os Termos de Uso e Políticas de Privacidade dos sites usando Inteligência Artificial.",
  "icons": {
    "16": "icon16.png",
    "32": "icon32.png",
    "48": "icon48.png",
    "128": "icon128.png"
  },
  "permissions": [
    "activeTab",
    "storage"
  ],
  "host_permissions": [
    "https://api-termos-privacidade.onrender.com/"
  ],
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"]
    }
  ]
}